# AI Engine Environment Configuration
# Copy file này sang .env và điền giá trị

# ============================================================
# ANTHROPIC — chọn MỘT trong hai cách sau:
# ============================================================

# CÁCH 1: Dùng proxy URL (ưu tiên nếu có)
# Nếu có ANTHROPIC_BASE_URL → SDK sẽ gọi đến URL này thay vì api.anthropic.com
# API key có thể để trống hoặc điền bất kỳ giá trị nào
ANTHROPIC_BASE_URL=http://192.168.0.101:8000

# CÁCH 2: Dùng Anthropic trực tiếp
# Lấy tại: https://console.anthropic.com/
# Bỏ comment dòng dưới nếu không dùng proxy
# ANTHROPIC_API_KEY=sk-ant-...

# Model Claude dùng để phân tích
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================================
# Prometheus (nơi lấy metrics)
# ============================================================
PROMETHEUS_URL=http://localhost:9090

# ============================================================
# Loki (nơi lấy logs)
# ============================================================
LOKI_URL=http://localhost:3100

# ============================================================
# AlertManager
# ============================================================
ALERTMANAGER_URL=http://localhost:9093

# ============================================================
# AI Engine Server
# ============================================================
AI_ENGINE_HOST=0.0.0.0
AI_ENGINE_PORT=8765

# ============================================================
# Phân tích định kỳ (giây) — mặc định 5 phút
# ============================================================
ANALYSIS_INTERVAL_SECONDS=300

# ============================================================
# Google Chat webhook (tùy chọn)
# Tạo tại: Google Chat Space → Manage webhooks
# ============================================================
GOOGLE_CHAT_WEBHOOK_URL=

# ============================================================
# Misc
# ============================================================
DB_PATH=./data/ai_engine.db

# ============================================================
# Authentication
# ============================================================
AUTH_USERNAME=admin
AUTH_PASSWORD=@ISystemInt3llig3nc3Platf()rm
# Thay bằng chuỗi ngẫu nhiên dài ≥ 32 ký tự khi deploy ra internet
# Tạo: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=change-me-in-production-32chars!!
# Session timeout (giây) — 28800 = 8 giờ
AUTH_SESSION_MAX_AGE=28800

LOG_LEVEL=INFO
